From c17669ed2cd37ac16b8c4295306df264a8a9b607 Mon Sep 17 00:00:00 2001
From: Henry Heino <personalizedrefrigerator@gmail.com>
Date: Mon, 18 May 2026 09:31:19 -0700
Subject: [PATCH 1/5] Server: Build smaller images

Excludes dev dependencies from the server Docker image.
---
 Dockerfile.server | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/Dockerfile.server b/Dockerfile.server
index 24cc4f2b4bc..e5dccd87aad 100644
--- a/Dockerfile.server
+++ b/Dockerfile.server
@@ -51,7 +51,12 @@ RUN sed --in-place '/onenote-converter/d' ./packages/lib/package.json
 
 RUN --mount=type=cache,target=/build/.yarn/cache --mount=type=cache,target=/build/.yarn/berry/cache\
     BUILD_SEQUENCIAL=1 yarn config set cacheFolder /build/.yarn/cache \
-    && yarn install --inline-builds
+    && yarn install --inline-builds \
+    # Running "yarn workspaces focus" removes dev dependencies and allows building smaller images.
+    # For it to work, the "postinstall" step needs to be disabled, since dev dependencies are used
+    # during the postinstall-triggered build step.
+    && sed --in-place 's/"postinstall": ".*"/"postinstall": ""/' ./package.json ./packages/*/package.json \
+    && yarn workspaces focus --production --all
 
 # =============================================================================
 # Final stage - we copy only the relevant files from the build stage and start

